{
  "window.commandCenter": true,
  "cursor.composer.shouldChimeAfterChatFinishes": true,
  "terminal.integrated.commandsToSkipShell": [
    "language-julia.interrupt",
    "workbench.action.terminal.focus",
    "workbench.action.focusActiveEditorGroup",
    "workbench.action.terminal.toggleTerminal"
  ],
  "terminal.integrated.focusAfterOpen": false,
  "julia.symbolCacheDownload": true,
  "julia.enableCrashReporter": true,
  "julia.numTestProcesses": 6,
  "julia.NumThreads": "auto",
  "editor.formatOnSave": true,
  "julia.enableTelemetry": true,
  "git.openRepositoryInParentFolders": "never",
  "git.confirmSync": false,
  "explorer.confirmDelete": false,
  "cursor.cpp.disabledLanguages": [],
  "explorer.confirmDragAndDrop": false,
  "cursor.cpp.enablePartialAccepts": true,
  "vim.useCtrlKeys": false,
  "vim.useSystemClipboard": true,
  "vim.smartRelativeLine": true,
  "editor.lineNumbers": "relative",
  "files.autoSave": "onFocusChange",
  "workbench.panel.defaultLocation": "right",
  "customLocalFormatters.formatters": [
    {
      "command": "julia --project=@runic --startup-file=no -e 'using Runic; exit(Runic.main(ARGS))'",
      "languages": ["julia"]
    }
  ],
  "[julia]": {
    "editor.defaultFormatter": "jkillian.custom-local-formatters",
    "editor.detectIndentation": false,
    "editor.insertSpaces": true,
    "editor.tabSize": 4,
    "files.insertFinalNewline": true,
    "files.trimFinalNewlines": true,
    "files.trimTrailingWhitespace": true,
    "editor.rulers": [92],
    "files.eol": "\n"
  },
  "remote.SSH.remotePlatform": {
    "bengal": "linux",
    "ml7": "linux"
  },
  "python.terminal.activateEnvironment": false,
  "workbench.colorTheme": "flexoki-light",
  "remote.autoForwardPortsSource": "hybrid",
  "git.suggestSmartCommit": false,
  "editor.cursorSurroundingLines": 8,
  "update.mode": "manual",
  "terminal.integrated.fontLigatures.enabled": true,
  "editor.fontFamily": "'JetBrainsMono Nerd Font', 'monospace', monospace",
  "window.confirmBeforeClose": "always",
  "diffEditor.ignoreTrimWhitespace": false,
  "extensions.experimental.affinity": {
    "asvetliakov.vscode-neovim": 1
  },
  "jetls-client.executable": {
    "path": "/home/kristian/.julia/bin/jetls",
    "threads": "auto"
  },
  "terminal.integrated.scrollback": 10000,
  "workbench.navigationControl.enabled": false,
  "window.titleBarStyle": "native",
  "julia.additionalArgs": [],
  "julia.editor": "nvim",
  "julia.execution.inlineResultsForCellEvaluation": true,
  "julia.inlayHints.static.variableTypes.enabled": false,
  "julia.inlayHints.static.enabled": true
}

