Host *
    ServerAliveInterval 60
    ServerAliveCountMax 1440
    IdentityFile ~/.ssh/id_ed25519
    IdentitiesOnly yes

Host saga
    User kholme
    Hostname saga.sigma2.no
    ForwardAgent yes
    setEnv TERM=xterm-256color
    ControlMaster auto
    ControlPath ~/.ssh/%r@%h:%p

Host uio
    Hostname login.math.uio.no
    user kholme

Host atalanta
    Hostname atalanta
    ProxyJump uio
    user kholme
    SendEnv TERM
    SetEnv TERM=xterm-256color

Host nam-shub*
    Hostname %h
    ProxyJump uio
    user kholme
    SendEnv TERM
    SetEnv TERM=xterm-256color

Host abacus*
    Hostname %h 
    ProxyJump uio
    user kholme
    SendEnv TERM
    SetEnv TERM=xterm-256color

Host freebio* bioint0* ml*
    HostName %h.hpc.uio.no
    User kholme
    ForwardAgent yes
    ProxyJump uio
    SendEnv TERM
    SetEnv TERM=xterm-256color

Host claw
    User claw
    Hostname claw

Host nrec1
    User ubuntu
    HostName 2001:700:2:8201::1242

Host fox
    Hostname fox.educloud.no
    User ec-kholme
    RequestTTY force
    RemoteCommand ssh -t login-1
    setEnv TERM=xterm-256color
    ControlMaster auto
    ControlPath ~/.ssh/controlsock-%h-%p
