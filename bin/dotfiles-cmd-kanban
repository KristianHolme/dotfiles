#!/usr/bin/env bash
set -Eeuo pipefail

# Daily kanban board: self-contained ~/Documents/kanban.html opened as a Chromium PWA
# on Hyprland special workspace "kanban" (toggle overlay with SUPER+ALT+K).
#
# Requires window rule in hypr/window-rules.conf (apply with dac or hyprctl reload).
#
# Environment:
#   DOTFILES_KANBAN_DIR  Directory for kanban.html (default: XDG_DOCUMENTS_DIR or ~/Documents)

usage() {
    cat <<'EOF'
Usage: dotfiles-cmd-kanban

Open or toggle a local kanban board (kanban.html) as a borderless browser app on the
Hyprland kanban special workspace. Creates kanban.html from dotfiles template if missing.
Regenerates kanban-theme.css from the current Omarchy theme on each launch.

Environment:
  DOTFILES_KANBAN_DIR  Override Documents directory for kanban.html
EOF
}

if [[ ${1:-} == "-h" || ${1:-} == "--help" ]]; then
    usage
    exit 0
fi

[[ -f ~/.config/user-dirs.dirs ]] && source ~/.config/user-dirs.dirs

kanban_dir="${DOTFILES_KANBAN_DIR:-${XDG_DOCUMENTS_DIR:-$HOME/Documents}}"
kanban_file="$kanban_dir/kanban.html"
theme_file="$kanban_dir/kanban-theme.css"
template="${HOME}/dotfiles/templates/kanban/kanban.html"
special_ws="kanban"
window_title="Kanban"

mkdir -p "$kanban_dir"

if [[ ! -f $kanban_file ]]; then
    if [[ ! -f $template ]]; then
        echo "dotfiles-cmd-kanban: missing template: $template" >&2
        exit 1
    fi
    cp "$template" "$kanban_file"
elif ! grep -q 'loadOmarchyTheme' "$kanban_file" && [[ -f $template ]]; then
    python3 - "$kanban_file" "$template" <<'PY'
import re
import sys
from pathlib import Path

existing, template = Path(sys.argv[1]), Path(sys.argv[2])
old = existing.read_text()
new = template.read_text()
match = re.search(
    r'(<script type="application/json" id="kanban-data">)(.*?)(</script>)',
    old,
    re.S,
)
if match:
    data_block = match.group(2)
    new = re.sub(
        r'(<script type="application/json" id="kanban-data">)(.*?)(</script>)',
        lambda m: m.group(1) + data_block + m.group(3),
        new,
        count=1,
        flags=re.S,
    )
existing.write_text(new)
PY
fi

generate_kanban_theme() {
    local colors_file="${HOME}/.config/omarchy/current/theme/colors.toml"
    [[ -f $colors_file ]] || return 0

    python3 - "$colors_file" "$theme_file" <<'PY'
import sys
from pathlib import Path

def parse_colors(path):
    colors = {}
    for raw in Path(path).read_text().splitlines():
        line = raw.split("#", 1)[0].strip()
        if "=" not in line:
            continue
        key, value = line.split("=", 1)
        colors[key.strip()] = value.strip().strip('"').strip("'")
    return colors

def pick(colors, *keys, default="#888888"):
    for key in keys:
        if key in colors:
            return colors[key]
    return default

def luminance(hex_color):
    h = hex_color.lstrip("#")
    if len(h) != 6:
        return 0.5
    r, g, b = (int(h[i : i + 2], 16) / 255 for i in (0, 2, 4))
    return 0.2126 * r + 0.7152 * g + 0.0722 * b

colors = parse_colors(sys.argv[1])
bg = pick(colors, "background")
surface = pick(colors, "color0", "selection_background", default=bg)
border = pick(colors, "color7", "color8")
text = pick(colors, "foreground")
muted = pick(colors, "color7", "color8")
accent = pick(colors, "accent", "color4")
danger = pick(colors, "color1", "color9")
warn_bg = pick(colors, "color3", "color11")
warn_fg = pick(colors, "background", "foreground")
scheme = "dark" if luminance(bg) < 0.5 else "light"

css = f""":root {{
  color-scheme: {scheme};
  --bg: {bg};
  --surface: {surface};
  --border: {border};
  --text: {text};
  --muted: {muted};
  --accent: {accent};
  --danger: {danger};
  --warn-bg: {warn_bg};
  --warn-fg: {warn_fg};
}}
"""
Path(sys.argv[2]).write_text(css)
PY
}

generate_kanban_theme

find_kanban_address() {
    hyprctl clients -j | jq -r --arg t "$window_title" '
        .[] |
        select(.title == $t or (.class | test("kanban\\.html"; "i"))) |
        .address' | head -n1
}

client_workspace() {
    local addr=$1
    hyprctl clients -j | jq -r --arg a "$addr" \
        '.[] | select(.address == $a) | .workspace.name' | head -n1
}

toggle_kanban_overlay() {
    hyprctl dispatch togglespecialworkspace "$special_ws"
}

ensure_kanban_on_special() {
    local addr=$1 ws
    ws=$(client_workspace "$addr")
    if [[ $ws == "special:${special_ws}" ]]; then
        return 0
    fi

    notify-send "Kanban window rule not active" \
        "Kanban opened on workspace ${ws:-unknown}. Run dac or hyprctl reload, then close and reopen Kanban." \
        -u critical -t 8000 2>/dev/null || true
    echo "dotfiles-cmd-kanban: kanban opened on '${ws:-unknown}', not special:${special_ws}" >&2
    echo "dotfiles-cmd-kanban: refusing to move windows; reload Hyprland config and try again" >&2
    return 1
}

if ! command -v hyprctl >/dev/null 2>&1; then
    echo "dotfiles-cmd-kanban: hyprctl not found (Hyprland required)" >&2
    exit 1
fi

if ! command -v jq >/dev/null 2>&1; then
    echo "dotfiles-cmd-kanban: jq not found" >&2
    exit 1
fi

if ! command -v omarchy-launch-webapp >/dev/null 2>&1; then
    echo "dotfiles-cmd-kanban: omarchy-launch-webapp not found" >&2
    exit 1
fi

addr=$(find_kanban_address)
if [[ -n $addr ]]; then
    ensure_kanban_on_special "$addr" || exit 1
    toggle_kanban_overlay
    exit 0
fi

file_url=$(python3 -c "import pathlib; print(pathlib.Path('${kanban_file}').resolve().as_uri())")

setsid omarchy-launch-webapp "$file_url" >/dev/null 2>&1 &

for _ in $(seq 1 50); do
    sleep 0.1
    addr=$(find_kanban_address)
    if [[ -n $addr ]]; then
        ensure_kanban_on_special "$addr" || exit 1
        toggle_kanban_overlay
        exit 0
    fi
done

echo "dotfiles-cmd-kanban: timed out waiting for Kanban window" >&2
exit 1
